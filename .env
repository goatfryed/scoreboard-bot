# =========================================================================
# WARNING: DO NOT ADD SENSITIVE TOKENS OR SECRETS TO THIS FILE.
# This file is tracked in git. For local development, place all sensitive
# values (like DISCORD_TOKEN and GITHUB_PAT) in a new file named '.env.local'.
# '.env.local' is git-ignored and will automatically override values here.
# =========================================================================

# --- Discord Configuration ---
# Your Discord Bot Token (Get from Discord Developer Portal -> Bot -> Token)
# DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord Application/Client ID (Get from Discord Developer Portal -> General Information)
# DISCORD_CLIENT_ID=your_client_id_here

# --- GitHub Configuration ---
# Personal Access Token (PAT) with read/write repo access to trigger workflow actions
# GITHUB_PAT=your_github_pat_here

# GitHub repository owner (e.g., goatfryed)
GITHUB_OWNER=goatfryed

# GitHub repository name (e.g., nw-scoreboard-reader)
GITHUB_REPO=nw-scoreboard-reader

# GitHub actions workflow filename (e.g., parse-clip.yml)
GITHUB_WORKFLOW_ID=parse-clip.yml

# --- Access Control ---
# Comma-separated list of Discord Guild (Server) IDs where the submit command will be registered. If empty, the submit command will not be registered on any server.
SERVER_WHITELIST=123456789012345678,987654321098765432

GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- MMR Leaderboard Configuration ---
MMR_SPREADSHEET_ID=1lJrTw9okwrOi9CyzLr_M3ecYi8cDcG4m-4Gtx-NsgCQ
MMR_SHEET_GID=558216310
MMR_CACHE_TTL_MS=600000